# Theettam Premium — boot-SAFE fragment for stock vendor_dlkm
# Applied on top of gki_defconfig after proven root/DroidSpaces wiring.
# FORBIDDEN (must stay off / never force-enable):
# CONFIG_CGROUP_PIDS is not set
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_NF_TABLES is not set
# CONFIG_BRIDGE_NETFILTER is not set
# Do not change CONFIG_HZ (base ships HZ_300 and boots; do not set to other values)

# Category A — expect empty/core-safe CRC
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_WRITEBACK=y
# Multi-comp if Kconfig present (ignored if unknown via merge_config)
CONFIG_ZRAM_MULTI_COMP=y

# Explicitly keep forbidden off even if a fragment tries to set them
# CONFIG_CGROUP_PIDS is not set
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_NF_TABLES is not set
# CONFIG_BRIDGE_NETFILTER is not set
# CONFIG_NETFILTER_XT_TARGET_TEE is not set
