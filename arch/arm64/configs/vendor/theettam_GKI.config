# SPDX-License-Identifier: GPL-2.0
# Theettam PREMIUM — bootable profile (alpha-2)
# Base: 6.1.175 + BORE + ADIOS | SukiSU + SUSFS | Droidspaces SAFE set
#
# CRITICAL — do NOT enable (on-device bootloop / vendor CRC break, proven on peridot):
#   CONFIG_CGROUP_DEVICE, CONFIG_CGROUP_PIDS
#   CONFIG_BRIDGE_NETFILTER, CONFIG_NF_TABLES
# See commits f37c68f464 / 88c1263bc9 and scripts/droidspaces/droidspaces.config
#
# export KMI_SYMBOL_LIST_STRICT_MODE=1
# Order: gki_defconfig + vendor/pineapple_GKI + vendor/peridot_GKI + this

# --- Root: SukiSU-Ultra + KPM + SUSFS ---
CONFIG_KSU=y
CONFIG_KPM=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y
# CONFIG_KSU_MANUAL_HOOK is not set
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_MAP=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
# CONFIG_KSU_SUSFS_ENABLE_LOG is not set

# --- Droidspaces SAFE (namespace isolation only; no CRC-breaking controllers) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_SYSVIPC=y
# DO NOT: CGROUP_DEVICE, CGROUP_PIDS (task_struct / css_set size → vendor CRC death)
# CONFIG_CGROUP_DEVICE is not set
# CONFIG_CGROUP_PIDS is not set
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_VETH=y
CONFIG_MACVLAN=y
# DO NOT: BRIDGE_NETFILTER / NF_TABLES (sched/core CRC break → bootloop #2)
# CONFIG_BRIDGE_NETFILTER is not set
# CONFIG_NF_TABLES is not set
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_CT_NETLINK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_OVERLAY_FS=y

# --- Perf / power (v2.1 product stack) ---
CONFIG_SCHED_BORE=y
CONFIG_MQ_IOSCHED_ADIOS=y
CONFIG_MQ_IOSCHED_DEFAULT_ADIOS=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"
CONFIG_NET_SCH_CAKE=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_FQ_CODEL=y
CONFIG_WIREGUARD=m
CONFIG_BOEFFLA_WL_BLOCKER=y
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
