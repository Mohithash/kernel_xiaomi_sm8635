# SPDX-License-Identifier: GPL-2.0
# Theettam Kernel — GKI fragment for POCO F6 (peridot / SM8635)
# Apply AFTER: gki_defconfig vendor/pineapple_GKI.config vendor/peridot_GKI.config
# Base: android14-6.1.175 (lts-175) + BORE + ADIOS
#
# make O=out \
#   gki_defconfig vendor/pineapple_GKI.config vendor/peridot_GKI.config \
#   vendor/theettam_GKI.config

# =============================================================================
# Phase 1 — Root stack (SukiSU-Ultra / KernelSU-Next + SUSFS v2.2.0 + KPM)
# These symbols are provided by integrated drivers (see theettam/scripts/integrate_root.sh).
# If a symbol is unknown at oldconfig, integration step has not been run yet.
# =============================================================================
CONFIG_KSU=y
# KernelSU-Next / SukiSU path (driver may expose either)
# CONFIG_KSU_MANUAL_HOOK is unset when using modern syscall hooks
# CONFIG_KSU_MANUAL_HOOK is not set
CONFIG_KPM=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_KALLSYMS_BASE_RELATIVE=y

# SUSFS v2.2.0 feature matrix (names match susfs4ksu / pershoot next-susfs)
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_SUS_MAP=y
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
# Runtime log spam off for production / battery
# CONFIG_KSU_SUSFS_ENABLE_LOG is not set

# =============================================================================
# Phase 2 — Native Droidspaces / LXC / Docker (user_ns + net)
# =============================================================================
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_MEMCG_SWAP=y
CONFIG_CGROUP_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_CHECKPOINT_RESTORE=y

# veth / macvlan for container networking + NAT helpers
CONFIG_VETH=y
CONFIG_MACVLAN=y
CONFIG_MACVTAP=y
CONFIG_BRIDGE=y
CONFIG_BRIDGE_NETFILTER=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_MANGLE=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_NAT=y
CONFIG_IP6_NF_TARGET_MASQUERADE=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_NETFILTER_XT_MATCH_MULTIPORT=y
CONFIG_NETFILTER_XT_MATCH_ADDRTYPE=y
CONFIG_NETFILTER_XT_MATCH_CONNTRACK=y
CONFIG_NETFILTER_XT_TARGET_CHECKSUM=y
CONFIG_IP_NF_TARGET_REDIRECT=y
CONFIG_NETFILTER_XT_MATCH_COMMENT=y

# openat2 path resolution (containers / seccomp-adjacent)
CONFIG_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y

# =============================================================================
# Phase 3 — Scheduler / I/O / power (BORE + ADIOS already in lts-175)
# =============================================================================
CONFIG_SCHED_BORE=y
CONFIG_MQ_IOSCHED_ADIOS=y
CONFIG_MQ_IOSCHED_DEFAULT_ADIOS=y

# MGLRU / memory
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED=y

# Networking performance (if not already forced by base)
CONFIG_TCP_CONG_BBR=y
CONFIG_TCP_CONG_BBR2=y
CONFIG_DEFAULT_BBR=y
CONFIG_NET_SCH_FQ_CODEL=y
CONFIG_DEFAULT_FQ_CODEL=y
CONFIG_WIREGUARD=y

# Theettam wakelock blocker (drivers/misc/boeffla_wl_blocker)
CONFIG_BOEFFLA_WL_BLOCKER=y

# Thermal: prefer generic framework hooks Voltage thermal-engine uses
CONFIG_THERMAL=y
CONFIG_THERMAL_GOV_POWER_ALLOCATOR=y
CONFIG_CPU_THERMAL=y
CONFIG_DEVFREQ_THERMAL=y

# KMI discipline (build system / gki also sets via cmdline env)
# KMI_SYMBOL_LIST_STRICT_MODE is a build flag, not a Kconfig — set in build.sh:
#   export KMI_SYMBOL_LIST_STRICT_MODE=1
